generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Client portal accounts — JSON columns mirror legacy client-portal.json shape.
model PortalUser {
  id                         String    @id @default(uuid())
  username                   String
  email                      String    @unique
  passwordHash               String    @map("password_hash")
  phone                      String    @default("")
  verificationChannel        String?   @map("verification_channel")
  signupVerificationPending  Boolean   @default(false) @map("signup_verification_pending")
  signupVerificationCodeHash String    @default("") @map("signup_verification_code_hash")
  signupVerificationExpiresAt DateTime? @map("signup_verification_expires_at")
  accountVerifiedAt          DateTime? @map("account_verified_at")
  passwordResetTokenHash     String    @default("") @map("password_reset_token_hash")
  passwordResetExpiresAt     DateTime? @map("password_reset_expires_at")
  fullName                   String    @default("") @map("full_name")
  serviceAddress             String    @default("") @map("service_address") @db.Text
  avatarDataUrl              String    @default("") @map("avatar_data_url") @db.Text
  lastLoginAt                DateTime? @map("last_login_at")

  ideas             Json @default("[]")
  invoices          Json @default("[]")
  projectStatus     Json @default("{}") @map("project_status")
  carpenterUploads  Json @default("[]") @map("carpenter_uploads")
  spacePhotos       Json @default("[]") @map("space_photos")
  aiPlannerActivity Json @default("[]") @map("ai_planner_activity")
  portalAnalytics   Json @default("{}") @map("portal_analytics")
  communicationLog  Json @default("[]") @map("communication_log")
  /// Formal job proposals (draft → sent → accepted); JSON array of WorkProposal records.
  workProposals     Json @default("[]") @map("work_proposals")
  /// Snapshot from request at registration (IP/geo headers when available).
  signupLocationLog Json? @map("signup_location_log")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  structuredJobs Job[] @relation("PortalUserStructuredJobs")

  @@map("portal_users")
}

/// Carpenter accounts — jobs stored as JSON array (legacy carpenter-app.json shape).
model CarpenterAccount {
  id                             String   @id @default(uuid())
  username                       String
  passwordHash                   String   @map("password_hash")
  fullName                       String   @map("full_name")
  email                          String   @default("")
  phone                          String   @default("")
  emergencyContactName           String   @default("") @map("emergency_contact_name")
  emergencyContactRelationship   String   @default("") @map("emergency_contact_relationship")
  emergencyContactPhone          String   @default("") @map("emergency_contact_phone")
  emergencyContactAlternatePhone String   @default("") @map("emergency_contact_alternate_phone")
  skillsSummary                  String   @default("") @map("skills_summary") @db.Text
  toolsInventory                 String   @default("") @map("tools_inventory") @db.Text
  hasLiabilityInsurance          Boolean  @default(false) @map("has_liability_insurance")
  liabilityInsuranceDetails      String   @default("") @map("liability_insurance_details") @db.Text
  hasWsib                        Boolean  @default(false) @map("has_wsib")
  wsibDetails                    String   @default("") @map("wsib_details") @db.Text
  availabilityNotes              String   @default("") @map("availability_notes") @db.Text
  availabilityCalendar           Json     @default("[]") @map("availability_calendar")
  googleCalendarConnected        Boolean  @default(false) @map("google_calendar_connected")
  googleCalendarEmail            String   @default("") @map("google_calendar_email")
  googleCalendarRefreshToken     String   @default("") @map("google_calendar_refresh_token") @db.Text
  profilePictureDataUrl          String   @default("") @map("profile_picture_data_url") @db.Text

  jobs Json @default("[]")
  /// Snapshot from request at registration (IP/geo headers when available).
  signupLocationLog Json? @map("signup_location_log")
  passwordResetTokenHash String @default("") @map("password_reset_token_hash")
  passwordResetExpiresAt  DateTime? @map("password_reset_expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assignedStructuredJobs Job[] @relation("CarpenterStructuredJobs")

  @@map("carpenter_users")
}

/// Paid booking work requests for admin CRM (legacy work-requests.json rows).
model AdminWorkRequest {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  status           String
  source           String   @default("booking")
  fullName         String   @map("full_name")
  email            String
  phone            String
  projectAddress   String   @map("project_address") @db.Text
  preferredDate    String   @map("preferred_date") @db.Text
  projectDetails   String   @map("project_details") @db.Text
  signatureName    String   @map("signature_name")
  stripeSessionId  String   @unique @map("stripe_session_id")
  paidAmountCents  Int      @map("paid_amount_cents")
  portalUserId     String   @map("portal_user_id")
  jobPlan          Json?    @map("job_plan")

  @@map("work_requests")
}

/// Structured job record — spatial intake from planner / CRM + pricing holds (150 min labor rule + materials).
/// When created from carpenter CRM intake/admin assign, `id` matches the embedded `CarpenterJob.id`. Standalone guest submits use a generated cuid only.
model Job {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now()) @map("created_at")
  customerPhone String   @map("customer_phone")
  /// Required for Stripe receipts / guest checkout when no portal account.
  customerEmail String   @default("") @map("customer_email")
  /// Pipeline: PENDING_REVIEW → PROPOSAL_SENT → CURRENT_JOB (deposit / mock / webhook) → COMPLETED; legacy: PAID, APPROVED_PENDING_PAYMENT.
  status        String   @default("PENDING_REVIEW")

  /// Spatial data (typically inches — align with Alex extraction pipeline).
  width        Float
  height       Float
  depth        Float
  dwellingType String   @map("dwelling_type")
  floorLevel   Int      @default(1) @map("floor_level")
  hasElevator  Boolean  @default(true) @map("has_elevator")

  renderUrl    String? @map("render_url")
  blueprintUrl String? @map("blueprint_url")
  shoppingList Json    @default("[]") @map("shopping_list")

  materialCost    Float @map("material_cost")
  estimatedHours  Float @map("estimated_hours")
  totalLaborHold  Float @map("total_labor_hold")
  /// Application rule: typically `150 + materialCost` (minimum labor hold + materials).
  immediateCharge Float @map("immediate_charge")

  /// Override for Stripe Checkout total (cents); defaults to rounded `immediateCharge` when null.
  paymentAmountCents Int? @map("payment_amount_cents")

  /// Magic token for optional guest checkout flows (always set on create).
  guestPayToken String? @unique @map("guest_pay_token")

  portalUserId String? @map("portal_user_id")
  portalUser   PortalUser? @relation("PortalUserStructuredJobs", fields: [portalUserId], references: [id], onDelete: SetNull)

  assignedCarpenterId String? @map("assigned_carpenter_id")
  assignedCarpenter   CarpenterAccount? @relation("CarpenterStructuredJobs", fields: [assignedCarpenterId], references: [id], onDelete: SetNull)

  stripeCheckoutSessionId String? @map("stripe_checkout_session_id")

  stripeLaborHoldCheckoutSessionId String? @map("stripe_labor_hold_checkout_session_id")

  /// Buffer breakdown, holds, and estimator audit trail (JSON).
  laborBreakdown Json @default("{}") @map("labor_breakdown")

  /// Generated scope / Terms summary appended at submit time.
  scopeOfWorkTerms String? @map("scope_of_work_terms") @db.Text

  /// Alex Phase 1 — Project North Star (e.g. built-ins, TV wall, trim).
  designCategory String? @map("design_category") @db.VarChar(500)
  /// Style / vibe label from intake (e.g. modern minimalist, traditional warm).
  designStyle String? @map("design_style") @db.VarChar(500)
  /// Combined use case, survey notes, removals/obstructions discussed (Gemini extract).
  scopeNotes String? @map("scope_notes") @db.Text

  /// Work proposal id when created from formal proposal intake (`portal_users.work_proposals` JSON).
  workProposalId String? @map("work_proposal_id")

  @@index([portalUserId])
  @@index([assignedCarpenterId])
  @@index([workProposalId])
  @@index([status])
  @@map("jobs")
}
